# ─── DealFlash — Variables d'environnement ───────────────────────────────
# Copier ce fichier en .env pour le développement local
# Sur Render, renseigner ces variables dans le Dashboard (Environment tab)

# Environnement
NODE_ENV=production           # "development" en local

# Port (Render impose 10000, localhost utilise 3001)
PORT=10000

# Chemin DB NeDB (Render : /opt/render/project/src/data)
DB_PATH=./data

# URL publique du service (injectée automatiquement par Render)
# RENDER_EXTERNAL_URL=https://dealflash-api.onrender.com

# URL du frontend (pour CORS)
FRONTEND_URL=https://dealflash.netlify.app

# Optionnel — Email alertes (SendGrid)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# ALERT_FROM=noreply@dealflash.fr
